{% if shop.metafields.my_app.announcement != blank %}
  <div id="my-app-announcement-banner" class="my-app-banner" role="alert" style="display: none;">
    <div class="my-app-banner-content">
      <p>{{ shop.metafields.my_app.announcement }}</p>
      <button class="my-app-banner-close" aria-label="Close Announcement" onclick="dismissAnnouncement()">
        &times;
      </button>
    </div>
  </div>

  <script>
    if (!sessionStorage.getItem('announcement_dismissed')) {
      document.getElementById('my-app-announcement-banner').style.display = 'block';
    }

    function dismissAnnouncement() {
      sessionStorage.setItem('announcement_dismissed', 'true');
      document.getElementById('my-app-announcement-banner').style.display = 'none';
    }
  </script>

  <style>
    .my-app-banner {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 999999;
      width: 100%;
      background-color: #000000;
      color: #ffffff;
      font-size: 14px;
      padding: 12px 15px;
      box-sizing: border-box;
      box-shadow: 0 4px 6px rgba(0,0,0,0.3);
      transform: translateY(-100%);
      animation: slideDown 0.5s ease forwards;
    }
    
    .my-app-banner-content {
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
    }

    .my-app-banner p {
      margin: 0;
      padding: 0 40px;
      text-align: center;
      font-family: inherit;
      line-height: 1.4;
    }

    .my-app-banner-close {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #ffffff;
      font-size: 24px;
      cursor: pointer;
      line-height: 1;
      padding: 0 10px;
      transition: opacity 0.2s;
    }

    .my-app-banner-close:hover {
      opacity: 0.7;
    }
    
    @keyframes slideDown {
      to {
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      .my-app-banner p {
        font-size: 12px;
        padding: 0 30px;
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": []
}
{% endschema %}
